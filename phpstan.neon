includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    excludePaths:
        # Vendor-published config; references the optional medialibrary-pro package.
        - config/media-library.php

    level: 7
